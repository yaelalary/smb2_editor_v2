{
  "name": "smb2-editor-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Web-based level editor for Super Mario Bros. 2 (NES, USA PRG0)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "extract-chr": "tsx scripts/extract-chr.ts",
    "convert-atlases": "tsx scripts/convert-metatile-atlases.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "pinia": "~3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "~3.5.32"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/pngjs": "^6.0.5",
    "@vitejs/plugin-vue": "~6.0.0",
    "@vue/eslint-config-typescript": "~14.1.0",
    "@vue/test-utils": "~2.4.6",
    "@vue/tsconfig": "~0.7.0",
    "eslint": "~9.15.0",
    "eslint-plugin-vue": "~9.31.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "vite": "~8.0.8",
    "vitest": "~4.1.4",
    "vue-tsc": "~2.1.10"
  }
}
